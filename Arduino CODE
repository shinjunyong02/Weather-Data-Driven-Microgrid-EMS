void drawBootSplashWithFastLedSequence(){
  tft.fillScreen(C_BG);
  tft.setTextColor(C_CYAN,C_BG);
  tft.setTextSize(2);

  const char* l1 = "Weather Data-Driven";
  const char* l2 = "Microgrid EMS";
  int16_t x1,y1,x2,y2;
  uint16_t w1,h1,w2,h2;
  tft.getTextBounds(l1,0,0,&x1,&y1,&w1,&h1);
  tft.getTextBounds(l2,0,0,&x2,&y2,&w2,&h2);
  tft.setCursor((320-w1)/2,92);  tft.print(l1);
  tft.setCursor((320-w2)/2,122); tft.print(l2);

  // 3초 동안 R -> Y -> G 신호등 LED 빠른 순차 점멸
  unsigned long sm = millis();
  int step = 0;
  while(millis() - sm < 3000UL){
    if(step == 0)      setTrafficLeds(true,false,false);
    else if(step == 1) setTrafficLeds(false,true,false);
    else               setTrafficLeds(false,false,true);
    step = (step + 1) % 3;
    delay(80);
  }
  setTrafficLeds(false,false,false);
}

