  char b[20]; strftime(b,sizeof(b),"%m/%d %H:%M",&ti); return String(b);
}
String getTimeOnlyString(){
  struct tm ti; if(!getLocalTime(&ti))return "--:--";
  char b[6]; strftime(b,sizeof(b),"%H:%M",&ti); return String(b);
}
String getDateStringOffset(int od){
  time_t n; time(&n); n+=od*86400;
  struct tm*t=localtime(&n); char b[9]; strftime(b,sizeof(b),"%Y%m%d",t); return String(b);
}
bool waitForTimeSync(unsigned long tms){
  unsigned long s=millis(); struct tm ti;
  while(millis()-s<tms){
    if(getLocalTime(&ti)&&ti.tm_year+1900>=2024)return true;
    // 시간 동기화 대기 중에도 LED 점멸이 멈추지 않도록 짧은 주기로 갱신
    updateTrafficLedBlink();
    delay(80);
  }
  return false;
}

// ================= KMA BASE =================
String getBaseDateForHour(int bh){
  time_t n; time(&n); struct tm*t=localtime(&n);
  if(t->tm_hour<bh){n-=24*3600;t=localtime(&n);}
  char db[9]; strftime(db,sizeof(db),"%Y%m%d",t); return String(db);
}
String twoDigitBaseTime(int bh){char tb[5];sprintf(tb,"%02d00",bh);return String(tb);}
int getLatestKmaBaseHour(){
  struct tm ti; if(!getLocalTime(&ti))return 5;
  int h=ti.tm_hour,m=ti.tm_min;
  // KMA 초단기/단기예보 데이터는 발표시각 직후 바로 안정적으로 조회되지 않는 경우가 있어
  // 부팅 직후 자동 호출 실패를 줄이기 위해 25분 전까지는 이전 발표시각을 사용한다.
  if(m<25)h--;
  if(h<0)h=23;
  if(h>=23)return 23; if(h>=20)return 20; if(h>=17)return 17; if(h>=14)return 14;
  if(h>=11)return 11; if(h>=8)return 8;   if(h>=5)return 5;   if(h>=2)return 2; return 23;
}

