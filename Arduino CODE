// ================= HW TIMER (API LED 점멸 전용) =================
hw_timer_t* apiLedHwTimer = NULL;
portMUX_TYPE apiLedTimerMux = portMUX_INITIALIZER_UNLOCKED;
volatile bool apiLedHwBlink = false;
volatile bool apiLedHwActive = false;

void IRAM_ATTR onApiLedTimer(){
  portENTER_CRITICAL_ISR(&apiLedTimerMux);
  if(apiLedHwActive){
    apiLedHwBlink = !apiLedHwBlink;
    digitalWrite(TRAFFIC_LED_R_PIN, apiLedHwBlink ? HIGH : LOW);
    digitalWrite(TRAFFIC_LED_Y_PIN, apiLedHwBlink ? HIGH : LOW);
    digitalWrite(TRAFFIC_LED_G_PIN, apiLedHwBlink ? HIGH : LOW);
  }
  portEXIT_CRITICAL_ISR(&apiLedTimerMux);
}

void startApiLedHwTimer(){
  apiLedHwActive = true;
  apiLedHwBlink  = false;

#if ESP_ARDUINO_VERSION_MAJOR >= 3
  if(apiLedHwTimer == NULL){
    apiLedHwTimer = timerBegin(1000000);              
    timerAttachInterrupt(apiLedHwTimer, &onApiLedTimer);
  }
  timerAlarm(apiLedHwTimer, 300000, true, 0);          
#else
  if(apiLedHwTimer == NULL){
    apiLedHwTimer = timerBegin(0, 80, true);           
    timerAttachInterrupt(apiLedHwTimer, &onApiLedTimer, true);
    timerAlarmWrite(apiLedHwTimer, 300000, true);      
  }
  timerAlarmEnable(apiLedHwTimer);
#endif
}

void stopApiLedHwTimer(){
  apiLedHwActive = false;
#if ESP_ARDUINO_VERSION_MAJOR < 3
  if(apiLedHwTimer != NULL) timerAlarmDisable(apiLedHwTimer);
#endif
}

