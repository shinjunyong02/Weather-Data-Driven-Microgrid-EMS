  if(pointInRect(x,y,16,78,130,34)){
    bool t=!allLoadOn; motorLoadOn=shouldForceMotorOff()?false:t; ledLoadOn=t;
    applyLoadOutputs(); delay(180); drawLoadControlPage();
  } else if(pointInRect(x,y,16,122,130,34)){
    motorLoadOn=isEcoModeActive()?false:!motorLoadOn;
    applyLoadOutputs(); delay(180); drawLoadControlPage();
  } else if(pointInRect(x,y,16,166,130,34)){
    ledLoadOn=!ledLoadOn; applyLoadOutputs(); delay(180); drawLoadControlPage();
  } else if(pointInRect(x,y,174,78,130,34)){
    powerSourceMode=POWER_SOURCE_FORCE_EXTERNAL;
    applyEssModeOutputs(); delay(180); drawLoadControlPage();
  } else if(pointInRect(x,y,174,122,130,34)){
    powerSourceMode=POWER_SOURCE_FORCE_BATTERY;
    applyEssModeOutputs(); delay(180); drawLoadControlPage();
  } else if(pointInRect(x,y,174,166,130,34)){
    powerSourceMode=POWER_SOURCE_AUTO;
    updateEssModeByBatteryAndForecast(); delay(180); drawLoadControlPage();
  }
}

