<script>
let curPage=1,lastData=null,rtS=[],rtL=[],MAXN=60;const titles=['제어 & 설정','EMS 대시보드','예보 & 분석'],bnis=['bni-ctrl','bni-home','bni-data'];function $(id){return document.getElementById(id)}function cls(id,c){let e=$(id);if(e)e.className=c}function txt(id,v){let e=$(id);if(e)e.textContent=v}function fmt(v,n){v=Number(v);return isFinite(v)?v.toFixed(n):(0).toFixed(n)}function level(v){v=Number(v)||0;return v<18?['LOW','badge-lo']:v<36?['MID','badge-mid']:['HIGH','badge-hi']}function isDesktopLayout(){
  return window.matchMedia('(min-width:800px) and (orientation:landscape)').matches;
}

function goPage(n){
  curPage=n;

  if(isDesktopLayout()){
    $('pages').style.transform='none';
    txt('page-title','기상정보 기반 마이크로그리드 EMS');
  }else{
    let w=document.querySelector('.page').clientWidth||393;
    $('pages').style.transform='translateX('+(-n*w)+'px)';
    txt('page-title',titles[n]);
  }

  bnis.forEach((id,i)=>{
    let el=$(id);
    if(!el)return;
    el.className='bni'+(i===n?' active':'');
    let dot=el.querySelector('.bni-dot');
    if(i===n&&!dot){
      dot=document.createElement('div');
      dot.className='bni-dot';
      el.appendChild(dot);
    }
    if(i!==n&&dot)dot.remove();
  });
}window.addEventListener('resize',()=>goPage(curPage));
function setToggle(id,on,dis){let e=$(id);if(!e)return;e.className='toggle'+(on?' on':'')+(dis?' disabled':'')}async function sendCmd(path){try{let sep=path.indexOf('?')>=0?'&':'?';await fetch(path+sep+'ajax=1',{cache:'no-store'});setTimeout(updateData,120)}catch(e){}}function toggleLoad(t){if(t==='motor'&&lastData&&lastData.ess_mode==='ECO')return;sendCmd('/load?target='+t+'&value=toggle')}function setSource(m){sendCmd('/source?mode='+m)}function ecoSlide(v){txt('eco-display',v+'%');$('eco-slider').style.background='linear-gradient(to right,#ffd60a '+v+'%,#2c2c2e '+v+'%)'}async function setEco(v){ecoSlide(v);try{await fetch('/setEco?value='+encodeURIComponent(v)+'&ajax=1',{cache:'no-store'});setTimeout(updateData,120)}catch(e){}}
function showTab(t){['today','tomorrow','after'].forEach(x=>{cls('tab-'+x,'tab '+(x===t?'active':''));cls('pane-'+x,'tabpane '+(x===t?'active':''))})}function hourTable(title,hours,arr,actualArr){
let isToday=(title==='오늘');

let h='<table class="hour-tbl"><tr>';
h+='<th>시간</th><th>'+title+' 발전량</th>';

if(isToday){
  h+='<th>실제 발전량</th>';
}

h+='<th>시간</th><th>'+title+' 발전량</th>';

if(isToday){
  h+='<th>실제 발전량</th>';
}

h+='</tr>';

let leftHours=(hours||[]).slice(0,7);
let leftVals=(arr||[]).slice(0,7);

let rightHours=(hours||[]).slice(7);
let rightVals=(arr||[]).slice(7);

for(let i=0;i<7;i++){
  let h1=leftHours[i];
  let v1=leftVals[i];
  let a1=(actualArr||[])[i] || 0;

  let h2=rightHours[i];
  let v2=rightVals[i];
  let a2=(actualArr||[])[i+7] || 0;

  h+='<tr>';

  // 좌측
  let leftHour=(h1!==undefined)?String(h1).padStart(2,'0')+':00':'';
  let leftVal=(v1!==undefined)?fmt(v1,2)+' Wh':'';

  h+='<td style="color:#636366">'+leftHour+'</td>';
  h+='<td>'+leftVal+'</td>';

  if(isToday){
    h+='<td style="color:#4cd964">'+fmt(a1,2)+' Wh</td>';
  }

  // 우측
  if(h2!==undefined){
    let rightHour=String(h2).padStart(2,'0')+':00';
    let rightVal=fmt(v2,2)+' Wh';

    h+='<td style="color:#636366">'+rightHour+'</td>';
    h+='<td>'+rightVal+'</td>';

    if(isToday){
      h+='<td style="color:#4cd964">'+fmt(a2,2)+' Wh</td>';
    }
  }else{
    h+='<td></td><td></td>';

    if(isToday){
      h+='<td></td>';
    }
  }

  h+='</tr>';
}

return h+'</table>';
}
function roundRect(ctx,x,y,w,h,r){ctx.beginPath();ctx.moveTo(x+r,y);ctx.arcTo(x+w,y,x+w,y+h,r);ctx.arcTo(x+w,y+h,x,y+h,r);ctx.arcTo(x,y+h,x,y,r);ctx.arcTo(x,y,x+w,y,r);ctx.closePath()}function drawRT(){
  let c=$('rt-canvas'),ctx=c.getContext('2d'),W=c.width,H=c.height;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#111';
  roundRect(ctx,0,0,W,H,8);
  ctx.fill();

  let all=rtS.concat(rtL);
  let mx=Math.max(1,...all)*1.15;

  // Y축 숫자를 넣기 위해 왼쪽 여백 확보
  let p={l:34,r:4,t:10,b:10};
  let gW=W-p.l-p.r;
  let gH=H-p.t-p.b;
  let n=Math.max(2,rtS.length);

  ctx.font='10px -apple-system,BlinkMacSystemFont,Segoe UI,Arial,sans-serif';
  ctx.textAlign='right';
  ctx.textBaseline='middle';
  ctx.fillStyle='rgba(255,255,255,.62)';
  ctx.strokeStyle='#2c2c2e';
  ctx.lineWidth=1;

  // Y축 자동 범례: 최대, 75%, 50%, 25%, 0
  for(let g=0;g<=4;g++){
    let ratio=g/4;
    let y=p.t+gH*ratio;
    let val=mx*(1-ratio);

    ctx.setLineDash([3,3]);
    ctx.beginPath();
    ctx.moveTo(p.l,y);
    ctx.lineTo(W-p.r,y);
    ctx.stroke();

    ctx.setLineDash([]);
    ctx.fillText(val.toFixed(1),p.l-5,y);
  }

  // Y축 단위
  ctx.textAlign='left';
  ctx.fillStyle='rgba(255,255,255,.50)';
  ctx.fillText('W',4,p.t-5);

  function line(data,color){
    ctx.strokeStyle=color;
    ctx.lineWidth=2;
    ctx.setLineDash([]);
    ctx.beginPath();

    data.forEach((v,i)=>{
      let x=p.l+i*(gW/(n-1));
      let y=p.t+gH-(v/mx)*gH;

      if(i===0)ctx.moveTo(x,y);
      else ctx.lineTo(x,y);
    });

    ctx.stroke();
  }

  line(rtL,'#64d2ff');
  line(rtS,'#ffd60a');

  txt('rt-max-label','최대 '+mx.toFixed(2)+' W');
}
function drawBars(canvasId,pred,act,hours){
  let c=$(canvasId),ctx=c.getContext('2d'),W=c.width,H=c.height;
  ctx.clearRect(0,0,W,H);

  let leftPad=28;
  let bottomPad=16;
  let topPad=10;

  let chartW=W-leftPad;
  let chartH=H-bottomPad-topPad;

  let mx=Math.max(1,...(pred||[]),...(act||[]))*1.18;

  ctx.strokeStyle='#3a3a3c';
  ctx.lineWidth=1;

  ctx.beginPath();
  ctx.moveTo(leftPad,topPad);
  ctx.lineTo(leftPad,H-bottomPad);
  ctx.lineTo(W,H-bottomPad);
  ctx.stroke();

  ctx.fillStyle='#8e8e93';
  ctx.font='10px -apple-system';

  for(let i=0;i<=4;i++){
    let val=(mx*(4-i)/4).toFixed(1);
    let y=topPad+(chartH*i/4);

    ctx.fillText(Number(val).toFixed(2),2,y+3);

    ctx.strokeStyle='#2c2c2e';
    ctx.setLineDash([3,3]);
    ctx.beginPath();
    ctx.moveTo(leftPad,y);
    ctx.lineTo(W,y);
    ctx.stroke();
  }

  ctx.setLineDash([]);

  let n=(hours||[]).length||13;
  let slot=chartW/n;
  let bw=Math.max(5,slot*.27);

  for(let i=0;i<n;i++){
    let x=leftPad+i*slot+slot*.18;

    let ph=((pred||[])[i]||0)/mx*chartH;
    let ah=((act||[])[i]||0)/mx*chartH;

    ctx.fillStyle='#64d2ff';
    roundRect(ctx,x,H-bottomPad-ph,bw,ph,2);
    ctx.fill();

    ctx.fillStyle='#30d158';
    roundRect(ctx,x+bw+3,H-bottomPad-ah,bw,ah,2);
    ctx.fill();

    if(i%2===0){
      ctx.fillStyle='#636366';
      ctx.fillText(String((hours||[])[i]||'').padStart(2,'0'),x,H-2);
    }
  }

  // 현재 시간 기준 노란 N 라인
  let now=new Date();
  let hour=now.getHours();
  let minute=now.getMinutes();

  if(hour>=6 && hour<=18){
    let pos=(hour-6)+(minute/60);
    let nx=leftPad+(pos*slot);

    ctx.strokeStyle='#ffd60a';
    ctx.lineWidth=2;
    ctx.setLineDash([5,4]);

    ctx.beginPath();
    ctx.moveTo(nx,topPad);
    ctx.lineTo(nx,H-bottomPad);
    ctx.stroke();

    ctx.setLineDash([]);

    ctx.fillStyle='#ffd60a';
    ctx.font='bold 11px -apple-system';
    ctx.fillText('N',nx-4,topPad-1);
  }
}
function updateForecastCards(d){[['today',d.today_gen_wh],['tomorrow',d.tomorrow_gen_wh],['after',d.after_gen_wh]].forEach(x=>{let lv=level(x[1]);txt('d-'+x[0],fmt(x[1],1));txt('b-'+x[0],lv[0]);cls('b-'+x[0],'d-badge '+lv[1])});txt('pane-today', '');$('pane-today').innerHTML=hourTable('오늘',d.hours,d.pred_hourly,d.actual_hourly);$('pane-tomorrow').innerHTML=hourTable('내일',d.hours,d.tomorrow_hourly);$('pane-after').innerHTML=hourTable('모레',d.hours,d.after_hourly);drawBars('hour-canvas',d.pred_hourly,d.actual_hourly,d.hours)}
function addLog(d){
  let html='';

  if(d.event_logs){
    for(let i=d.event_logs.length-1;i>=0;i--){
      let raw=d.event_logs[i];
      let sp=raw.split('|');

      let tm=sp[0]||'--:--';
      let msg=sp[1]||raw;

      let color='#64d2ff';

      if(msg.includes('외부전원')) color='#ff453a';
      else if(msg.includes('배터리')) color='#30d158';
      else if(msg.includes('API')) color='#a78bfa';
      else if(msg.includes('WiFi')) color='#ffd60a';

      html += `
      <div class="log-item">
        <div class="log-dot" style="background:${color}"></div>
        <div>
          <div class="log-msg">${msg}</div>
          <div class="log-time">${tm}</div>
        </div>
      </div>`;
    }
  }

  $('log-list').innerHTML=html;
}
async function updateData(){try{let r=await fetch('/ina',{cache:'no-store'}),d=await r.json();lastData=d;let now=new Date();if(isDesktopLayout()){
  txt('clock',now.toLocaleTimeString('ko',{hour:'2-digit',minute:'2-digit'}));
