// ================= LED =================
void setTrafficLeds(bool r,bool y,bool g){
  digitalWrite(TRAFFIC_LED_R_PIN,r?HIGH:LOW);
  digitalWrite(TRAFFIC_LED_Y_PIN,y?HIGH:LOW);
  digitalWrite(TRAFFIC_LED_G_PIN,g?HIGH:LOW);
}

void updateEssSourceLeds(){
  // LED 의미:
  // Y = ECO 모드 표시
  // R = 외부전원 사용 / 외부전원 전환 대기 중 점멸
  // G = 내부 배터리 사용
  bool eco = isEcoModeActive();

  // 사용자가 수동으로 외부전원을 선택한 경우:
  // 5초 대기 중에는 실제 전원은 아직 내부 배터리이므로 G ON,
  // 외부전원 전환 대기는 R 점멸로 표시한다.
  if(manualExternalDelayActive){
    unsigned long now = millis();
    if(now - trafficLedLastToggle >= 250UL){
      trafficLedLastToggle = now;
      trafficLedBlinkState = !trafficLedBlinkState;
    }
    setTrafficLeds(trafficLedBlinkState, false, true);
    return;
  }

  if(ecoExternalDelayActive){
    unsigned long now = millis();
    if(now - trafficLedLastToggle >= 250UL){
      trafficLedLastToggle = now;
      trafficLedBlinkState = !trafficLedBlinkState;
    }

    // 대기 중에는 아직 내부 배터리 사용이므로 G ON,
    // ECO 상태는 Y ON, 외부전원 전환 대기는 R 점멸로 표시.
    setTrafficLeds(trafficLedBlinkState, eco, true);
    return;
  }

  bool external = (digitalRead(POWER_RELAY_PIN) == POWER_RELAY_EXTERNAL_ON);
  setTrafficLeds(external, eco, !external);
}

// 일반 LED 점멸 (비blocking 구간에서만 사용)
void updateTrafficLedBlink(){
  if(apiLedHwActive) return;  // HW 타이머가 담당 중이면 skip
  unsigned long now=millis(); unsigned long iv=180;

  if(wifiDisconnectedAlert && trafficLedMode!=LED_MODE_WIFI_CONNECTING && trafficLedMode!=LED_MODE_API_LOADING){
    if(now-trafficLedLastToggle>=500){
      trafficLedLastToggle=now;
      trafficLedBlinkState=!trafficLedBlinkState;
    }
    bool eco=isEcoModeActive();
    bool external = (digitalRead(POWER_RELAY_PIN) == POWER_RELAY_EXTERNAL_ON);
    setTrafficLeds(trafficLedBlinkState, eco, !external);
    return;
  }

  switch(trafficLedMode){
    case LED_MODE_ESS_ECO:       updateEssSourceLeds(); return;
    case LED_MODE_ESS_NORMAL:    updateEssSourceLeds(); return;
    case LED_MODE_WIFI_CONNECTED:setTrafficLeds(false,false,true);  return;
    case LED_MODE_OFF:           setTrafficLeds(false,false,false); return;
    case LED_MODE_TIME_SYNC:     iv=250; break;
    case LED_MODE_API_LOADING:   iv=300; break;
    default: break;
  }
  if(now-trafficLedLastToggle>=iv){trafficLedLastToggle=now;trafficLedBlinkState=!trafficLedBlinkState;}
  switch(trafficLedMode){
    case LED_MODE_WIFI_CONNECTING: setTrafficLeds(false,trafficLedBlinkState,false); break;
    case LED_MODE_WIFI_FAILED:     setTrafficLeds(trafficLedBlinkState,false,false); break;
    case LED_MODE_TIME_SYNC:       setTrafficLeds(false,false,trafficLedBlinkState); break;
    case LED_MODE_API_FAILED:      setTrafficLeds(trafficLedBlinkState,trafficLedBlinkState,false); break;
    case LED_MODE_API_LOADING:     setTrafficLeds(trafficLedBlinkState,trafficLedBlinkState,trafficLedBlinkState); break;
    default: break;
  }
}

// ================= ESS MODE =================
void forceBatteryPowerMode(){
  essMode="NORMAL";
  cancelEcoExternalDelay();
  if(powerSourceMode == POWER_SOURCE_AUTO) digitalWrite(POWER_RELAY_PIN,POWER_RELAY_BATTERY_ON);
  trafficLedMode=LED_MODE_ESS_NORMAL;
  updateEssSourceLeds();
}
bool isEcoModeActive(){return essMode=="ECO";}
bool shouldForceMotorOff(){
  return (essMode=="ECO" && batteryPercent<=ecoModeThresholdPercent);
}

void cancelEcoExternalDelay(){
  ecoExternalDelayActive = false;
}

void cancelManualExternalDelay(){
  manualExternalDelayActive = false;
}

void startManualExternalDelay(){
  manualExternalDelayActive = true;
  manualExternalDelayStartMs = millis();
  trafficLedLastToggle = millis() - 250UL;
  trafficLedBlinkState = false;

  // 외부전원으로 전환하기 전 5초 동안 내부 배터리를 유지한다.
  essMode = "MANUAL";
  digitalWrite(POWER_RELAY_PIN, POWER_RELAY_BATTERY_ON);
  trafficLedMode = LED_MODE_ESS_NORMAL;
  updateEssSourceLeds();

  addEventLog("외부전원 전환 대기");
  Serial.println("[ESS] Manual external selected. Waiting 5s on battery before switching to external power.");
}

void startEcoExternalDelay(){
  ecoExternalDelayActive = true;
  ecoExternalDelayStartMs = millis();
  trafficLedLastToggle = millis() - 250UL;
  trafficLedBlinkState = false;

  // 외부전원 전환 전 5초 동안 내부 배터리를 유지한다.
  digitalWrite(POWER_RELAY_PIN, POWER_RELAY_BATTERY_ON);
  trafficLedMode = LED_MODE_ESS_ECO;
  updateEssSourceLeds();

  Serial.println("[ESS] ECO detected. Waiting 5s on battery before switching to external power.");
}

void updateEcoExternalDelay(){
  if(!ecoExternalDelayActive) return;

  // 사용자가 수동 외부/배터리로 바꾸거나 ECO가 해제되면 대기 취소
  if(powerSourceMode != POWER_SOURCE_AUTO || !isEcoModeActive()){
    cancelEcoExternalDelay();
    updateEssSourceLeds();
    return;
  }

  if(millis() - ecoExternalDelayStartMs >= ECO_EXTERNAL_TRANSFER_DELAY_MS){
    ecoExternalDelayActive = false;
    digitalWrite(POWER_RELAY_PIN, POWER_RELAY_EXTERNAL_ON);
    addEventLog("외부전원 전환");
    trafficLedMode = LED_MODE_ESS_ECO;
    updateEssSourceLeds();
    Serial.println("[ESS] ECO transfer delay finished. Switched to external power.");

    if(currentPage==PAGE_LOAD) drawLoadControlPage();
    if(currentPage==PAGE_MAIN) updateMainDynamicValues();
  }
}

void updateManualExternalDelay(){
  if(!manualExternalDelayActive) return;

  // 대기 중 사용자가 AUTO 또는 배터리 강제 모드로 바꾸면 수동 외부전원 대기를 취소한다.
  if(powerSourceMode != POWER_SOURCE_FORCE_EXTERNAL){
    cancelManualExternalDelay();
    updateEssSourceLeds();
    return;
  }

  if(millis() - manualExternalDelayStartMs >= ECO_EXTERNAL_TRANSFER_DELAY_MS){
    manualExternalDelayActive = false;
    essMode = "MANUAL";
    digitalWrite(POWER_RELAY_PIN, POWER_RELAY_EXTERNAL_ON);
    addEventLog("외부전원 전환");
    trafficLedMode = LED_MODE_ESS_NORMAL;
    updateEssSourceLeds();
    Serial.println("[ESS] Manual external delay finished. Switched to external power.");

    if(currentPage==PAGE_LOAD) drawLoadControlPage();
    if(currentPage==PAGE_MAIN) updateMainDynamicValues();
  }
}

void applyEssModeOutputs(){
  // Manual source selection: bypass the automatic ESS source algorithm.
  // AUTO mode below keeps the existing forecast/battery-based algorithm.
  if(powerSourceMode == POWER_SOURCE_FORCE_EXTERNAL){
    cancelEcoExternalDelay();
    essMode="MANUAL";

    // 이미 외부전원 사용 중이면 즉시 상태만 갱신한다.
    // 내부 배터리 사용 중 외부전원을 선택한 경우에는 5초 대기 후 전환한다.
    if(digitalRead(POWER_RELAY_PIN) != POWER_RELAY_EXTERNAL_ON){
      if(!manualExternalDelayActive) startManualExternalDelay();
      applyLoadOutputs();
      return;
    }

    cancelManualExternalDelay();
    digitalWrite(POWER_RELAY_PIN,POWER_RELAY_EXTERNAL_ON);
    trafficLedMode=LED_MODE_ESS_NORMAL;
    applyLoadOutputs();
    updateEssSourceLeds();
    return;
  }

  if(powerSourceMode == POWER_SOURCE_FORCE_BATTERY){
    cancelEcoExternalDelay();
    cancelManualExternalDelay();
    essMode="MANUAL";
    // Safety protection: at 10% or lower, external power is forced even in manual battery mode.
    if(batteryPercent <= CRITICAL_BATTERY_EXTERNAL_PERCENT)
      digitalWrite(POWER_RELAY_PIN,POWER_RELAY_EXTERNAL_ON);
    else
      digitalWrite(POWER_RELAY_PIN,POWER_RELAY_BATTERY_ON);
      addEventLog("배터리 사용 전환");
    trafficLedMode=LED_MODE_ESS_NORMAL;
    applyLoadOutputs();
    updateEssSourceLeds();
    return;
  }

  // AUTO 모드로 돌아오면 수동 외부전원 전환 대기는 취소한다.
  cancelManualExternalDelay();

  // AUTO: ECO 모드이면 외부전원으로 가되, 바로 전환하지 않고 5초 동안 배터리 유지
  if(isEcoModeActive()){
    if(shouldForceMotorOff()) motorLoadOn=false;
    digitalWrite(MOTOR_RELAY_PIN,MOTOR_RELAY_OFF);

    if(digitalRead(POWER_RELAY_PIN) != POWER_RELAY_EXTERNAL_ON && !ecoExternalDelayActive){
      startEcoExternalDelay();
    }

    trafficLedMode=LED_MODE_ESS_ECO;
  }else{
    cancelEcoExternalDelay();
    digitalWrite(POWER_RELAY_PIN,POWER_RELAY_BATTERY_ON);
    trafficLedMode=LED_MODE_ESS_NORMAL;
  }
  applyLoadOutputs();
  updateEssSourceLeds();
}
void updateEssModeByBatteryAndForecast(){
  if(powerSourceMode != POWER_SOURCE_AUTO){
    applyEssModeOutputs();
    return;
  }
  const char*tl=genLevelText(tomorrowGenWh);
  if(!initialKmaFetched||!isApiForecastOk()){forceBatteryPowerMode();return;}
  if(batteryPercent<=ecoModeThresholdPercent) essMode="ECO";
  else if(strcmp(tl,"LOW")==0)                essMode="ECO";
  else                                         essMode="NORMAL";
  applyEssModeOutputs();
}
void updateEssModeByTomorrowForecast(){updateEssModeByBatteryAndForecast();}

