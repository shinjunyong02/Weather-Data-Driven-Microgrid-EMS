  const int BAR_W=max(6, min(8, (SLOT_W-4)/2));
  float maxWh=1.0f;
  for(int i=0;i<SOLAR_SLOT_COUNT;i++){
    if(todayHourlyGenWh[i]>maxWh) maxWh=todayHourlyGenWh[i];
    if(actualHourlyWh[i]>maxWh)   maxWh=actualHourlyWh[i];
  }
  if(currentSlotAccumWh>maxWh) maxWh=currentSlotAccumWh;
  maxWh*=1.15f;

  tft.drawLine(CHART_X-1,CHART_Y,CHART_X-1,CHART_BOT,C_GRAY);
  tft.drawLine(CHART_X-1,CHART_BOT,CHART_X+SLOT_W*SOLAR_SLOT_COUNT,CHART_BOT,C_GRAY);
  tft.setTextSize(1); tft.setTextColor(C_GRAY,C_BG);
  char yLab[10];
  dtostrf(maxWh/1.15f,4,1,yLab);
  tft.setCursor(1,CHART_Y); tft.print(yLab);
  tft.drawLine(CHART_X-3,CHART_Y,CHART_X-1,CHART_Y,C_GRAY);
  dtostrf((maxWh/1.15f)/2.0f,4,1,yLab);
  tft.setCursor(1,CHART_Y+CHART_H/2-4); tft.print(yLab);
  tft.drawLine(CHART_X-3,CHART_Y+CHART_H/2,CHART_X-1,CHART_Y+CHART_H/2,C_GRAY);
  for(int dx=CHART_X;dx<CHART_X+SLOT_W*SOLAR_SLOT_COUNT;dx+=4)
    tft.drawPixel(dx,CHART_Y+CHART_H/2,0x2945);
  tft.setCursor(1,CHART_BOT-8); tft.print("0.0");
  tft.drawLine(CHART_X-3,CHART_BOT,CHART_X-1,CHART_BOT,C_GRAY);

  struct tm ti; int nh=14,nm=0;
  if(getLocalTime(&ti)){nh=ti.tm_hour;nm=ti.tm_min;}
  for(int i=0;i<SOLAR_SLOT_COUNT;i++){
    int sh=SOLAR_SLOT_START_HOUR+i, bx=CHART_X+i*SLOT_W;
    float pw=todayHourlyGenWh[i];
    if(pw>0&&maxWh>0){int bh=constrain((int)(pw/maxWh*(CHART_H-1)),1,CHART_H-1);tft.fillRect(bx+1,CHART_BOT-bh,BAR_W,bh,C_CYAN);}
    float aw=0;
    if(sh<nh) aw=actualHourlyWh[i]; else if(sh==nh) aw=currentSlotAccumWh;
    if(aw>0&&maxWh>0){int bh=constrain((int)(aw/maxWh*(CHART_H-1)),1,CHART_H-1);tft.fillRect(bx+1+BAR_W+2,CHART_BOT-bh,BAR_W,bh,C_GREEN);}
    if(sh%2==0){tft.setTextSize(1);tft.setTextColor(C_GRAY,C_BG);tft.setCursor(bx+(sh<10?4:1),CHART_BOT+3);tft.print(sh);}
  }
  if(nh>=SOLAR_SLOT_START_HOUR&&nh<=SOLAR_SLOT_END_HOUR){
    float fh=(float)(nh-SOLAR_SLOT_START_HOUR)+nm/60.0f;
    int nx=constrain(CHART_X+(int)(fh*SLOT_W),CHART_X,CHART_X+SLOT_W*SOLAR_SLOT_COUNT-1);
    for(int dy=CHART_Y;dy<CHART_BOT;dy++) if((dy/2)%2==0) tft.drawPixel(nx,dy,C_YELLOW);
    tft.setTextSize(1); tft.setTextColor(C_YELLOW,C_BG);
    // NOW 텍스트: 그래프 하단(CHART_BOT 아래)에 표시하여 범례와 겹침 방지
    int lx=constrain(nx-8,CHART_X,CHART_X+SLOT_W*SOLAR_SLOT_COUNT-22);
    tft.setCursor(lx,CHART_BOT+3); tft.print("N");
  }
}

