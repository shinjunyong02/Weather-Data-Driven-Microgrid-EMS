void handleWebInaJson(){
  float chV[3] = {0,0,0};
  float chI[3] = {0,0,0};
  float chP[3] = {0,0,0};

  if(ina3221OK){
    for(uint8_t i=0;i<3;i++){
      chV[i] = ina3221.getBusVoltage(i);
      chI[i] = ina3221.getCurrentAmps(i);
      chP[i] = chV[i] * fabs(chI[i]);
    }
  }

  float totalActual=currentSlotAccumWh;
  for(int i=0;i<SOLAR_SLOT_COUNT;i++) totalActual+=actualHourlyWh[i];

  float solarAlt = 0.0f;
  float solarAz = 0.0f;
  float shadowFactor = 0.0f;
  struct tm ti;
  if(getLocalTime(&ti)){
    float hourUTC = (float)ti.tm_hour - 9.0f + (float)ti.tm_min/60.0f + (float)ti.tm_sec/3600.0f;
    SolarPos sp = calcSolarPosition(ti.tm_year + 1900, ti.tm_mon + 1, ti.tm_mday, hourUTC);
    solarAlt = sp.altitude;
    solarAz = sp.azimuth;
    shadowFactor = calcShadowFactor(sp.altitude);
  }

  String json;
  json.reserve(3400);
  json += "{";
  json += "\"ina_ok\":"; json += (ina3221OK ? "true" : "false"); json += ",";
  json += "\"web_ok\":"; json += ((webServerReady && WiFi.status()==WL_CONNECTED) ? "true" : "false"); json += ",";
  json += "\"uptime_ms\":"; json += String(millis()); json += ",";
  json += "\"wifi_status\":\""; json += jsonEscape(wifiStatus); json += "\",";
  json += "\"ip\":\""; json += (WiFi.status()==WL_CONNECTED?WiFi.localIP().toString():String("---")); json += "\",";
  json += "\"api_status\":\""; json += jsonEscape(apiStatus); json += "\",";
  json += "\"last_api_sync\":\""; json += jsonEscape(lastApiSync); json += "\",";
  json += "\"battery_percent\":"; json += String(batteryPercent); json += ",";
  json += "\"battery_voltage\":"; json += String(batteryVoltage,3); json += ",";
  json += "\"battery_current\":"; json += String(batteryCurrent,4); json += ",";
  json += "\"current_capacity_ah\":"; json += String(currentCapacityAh,3); json += ",";
  json += "\"battery_capacity_ah\":"; json += String(BATTERY_CAPACITY_AH,3); json += ",";
  json += "\"eco_threshold\":"; json += String(ecoModeThresholdPercent); json += ",";
  json += "\"ess_mode\":\""; json += jsonEscape(essMode); json += "\",";
  json += "\"power_mode\":\""; json += powerSourceModeText(); json += "\",";
  json += "\"power_mode_value\":\""; json += powerSourceModeValue(); json += "\",";
  json += "\"active_source\":\""; json += activePowerSourceText(); json += "\",";
  json += "\"solar_power\":"; json += String(solarPower,2); json += ",";
  json += "\"load_power\":"; json += String(loadPower,2); json += ",";
  json += "\"today_gen_wh\":"; json += String(todayGenWh,2); json += ",";
  json += "\"tomorrow_gen_wh\":"; json += String(tomorrowGenWh,2); json += ",";
  json += "\"after_gen_wh\":"; json += String(afterTomorrowGenWh,2); json += ",";
  json += "\"total_actual_wh\":"; json += String(totalActual,2); json += ",";
  json += "\"solar_altitude\":"; json += String(solarAlt,2); json += ",";
  json += "\"solar_azimuth\":"; json += String(solarAz,2); json += ",";
  json += "\"shadow_factor\":"; json += String(shadowFactor,2); json += ",";
  json += "\"all_load_on\":"; json += (allLoadOn ? "true" : "false"); json += ",";
  json += "\"motor_load_on\":"; json += (motorLoadOn ? "true" : "false"); json += ",";
  json += "\"led_load_on\":"; json += (ledLoadOn ? "true" : "false"); json += ",";
  json += "\"hours\":[";
  for(int i=0;i<SOLAR_SLOT_COUNT;i++){ if(i>0) json += ","; json += String(SOLAR_SLOT_START_HOUR+i); }
  json += "],\"pred_hourly\":[";
  for(int i=0;i<SOLAR_SLOT_COUNT;i++){ if(i>0) json += ","; json += String(todayHourlyGenWh[i],2); }
  json += "],\"tomorrow_hourly\":[";
  for(int i=0;i<SOLAR_SLOT_COUNT;i++){ if(i>0) json += ","; json += String(tomorrowHourlyGenWh[i],2); }
  json += "],\"after_hourly\":[";
  for(int i=0;i<SOLAR_SLOT_COUNT;i++){ if(i>0) json += ","; json += String(afterTomorrowHourlyGenWh[i],2); }
  json += "],\"actual_hourly\":[";
  int nh=-1; if(getLocalTime(&ti)) nh=ti.tm_hour;
  for(int i=0;i<SOLAR_SLOT_COUNT;i++){
    if(i>0) json += ",";
    int sh=SOLAR_SLOT_START_HOUR+i;
    float aw=(sh==nh)?currentSlotAccumWh:actualHourlyWh[i];
    json += String(aw,2);
  }
  json += "],\"channels\":[";
  const char* names[3] = {"CH1 Solar", "CH2 Battery", "CH3 Load"};
  for(uint8_t i=0;i<3;i++){
    if(i>0) json += ",";
    json += "{";
    json += "\"name\":\""; json += names[i]; json += "\",";
    appendJsonFloat(json, "voltage", chV[i], 3); json += ",";
    appendJsonFloat(json, "current", chI[i], 4); json += ",";
    appendJsonFloat(json, "power", chP[i], 3);
    json += "}";
  }
  json += "],\"event_logs\":[";

for(int i=0;i<eventLogCount;i++){
  if(i>0) json += ",";
  json += "\"" + jsonEscape(eventLogs[i]) + "\"";
}

json += "]}";
  server.send(200, "application/json", json);
}

void handleWebRoot(){
  server.send_P(200, "text/html", WEB_INDEX);
}

void handleWebSetEco(){
  if(server.hasArg("value")){
    int newThreshold = constrain(server.arg("value").toInt(), 5, 95);

    if(newThreshold != ecoModeThresholdPercent){
      ecoModeThresholdPercent = newThreshold;
      saveEcoThresholdToNVS();
      addEventLog("ECO 기준 저장 " + String(ecoModeThresholdPercent) + "%");
    }

    updateEssModeByBatteryAndForecast();
  }

  // AJAX 요청은 현재 웹앱 화면을 유지해야 하므로 절대 홈(/)으로 리다이렉트하지 않는다.
  if(server.hasArg("ajax")){
    server.sendHeader("Cache-Control", "no-store");
    server.send(200, "text/plain", "OK");
  } else {
    server.sendHeader("Location", "/");
    server.send(303);
  }
}

void handleWebSetSource(){
  String m = server.arg("mode");
  if(m=="ext")      powerSourceMode = POWER_SOURCE_FORCE_EXTERNAL;
  else if(m=="bat") powerSourceMode = POWER_SOURCE_FORCE_BATTERY;
  else               powerSourceMode = POWER_SOURCE_AUTO;

  if(powerSourceMode==POWER_SOURCE_AUTO) updateEssModeByBatteryAndForecast();
  else applyEssModeOutputs();

  if(currentPage==PAGE_LOAD) drawLoadControlPage();
  if(currentPage==PAGE_MAIN) updateMainDynamicValues();

  if(server.hasArg("ajax")) server.send(200,"text/plain","OK");
  else { server.sendHeader("Location","/"); server.send(303); }
}

void handleWebSetLoad(){
  String target = server.arg("target");
  String value  = server.arg("value");

  if(target=="all"){
    bool t = (value=="on") ? true : (value=="off") ? false : !allLoadOn;
    motorLoadOn = isEcoModeActive() ? false : t;
    ledLoadOn = t;
  } else if(target=="motor"){
    if(!shouldForceMotorOff()){
      if(value=="on") motorLoadOn = true;
      else if(value=="off") motorLoadOn = false;
      else motorLoadOn = !motorLoadOn;
    }
  } else if(target=="led"){
    if(value=="on") ledLoadOn = true;
    else if(value=="off") ledLoadOn = false;
    else ledLoadOn = !ledLoadOn;
  }
  applyLoadOutputs();
  if(currentPage==PAGE_LOAD) drawLoadControlPage();
  if(currentPage==PAGE_MAIN) updateMainDynamicValues();
  if(server.hasArg("ajax")) server.send(200,"text/plain","OK");
  else { server.sendHeader("Location","/"); server.send(303); }
}

void handleWebWifiReconnect(){
  doWifiReconnect();
  if(server.hasArg("ajax")) server.send(200,"text/plain","OK");
  else { server.sendHeader("Location","/"); server.send(303); }
}

void handleWebApiRefresh(){
  doApiRefresh();
  if(server.hasArg("ajax")) server.send(200,"text/plain","OK");
  else { server.sendHeader("Location","/"); server.send(303); }
}

void handleWebNotFound(){
  server.send(404,"text/plain","Not found");
}

void setupWebServer(){
  server.on("/", handleWebRoot);
  server.on("/ina", handleWebInaJson);
  server.on("/setEco", handleWebSetEco);
  server.on("/source", handleWebSetSource);
  server.on("/load", handleWebSetLoad);
  server.on("/wifiReconnect", handleWebWifiReconnect);
  server.on("/apiRefresh", handleWebApiRefresh);
  server.onNotFound(handleWebNotFound);
  server.begin();
  webServerReady = true;
  Serial.println("[WEB] iPhone-style server started on port 80");
}

