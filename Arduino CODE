String powerSourceModeValue(){
  switch(powerSourceMode){
    case POWER_SOURCE_FORCE_EXTERNAL: return "ext";
    case POWER_SOURCE_FORCE_BATTERY:  return "bat";
    default:                          return "auto";
  }
}

String jsonEscape(const String& s){
  String out;
  out.reserve(s.length()+4);
  for(size_t i=0;i<s.length();i++){
    char c=s[i];
    if(c=='\\' || c=='\"'){ out += '\\'; out += c; }
    else if(c=='\n') out += "\\n";
    else if(c=='\r') out += "\\r";
    else out += c;
  }
  return out;
}

void appendJsonFloat(String& json, const char* key, float value, int digits){
  json += "\"";
  json += key;
  json += "\":";
  json += String(value, digits);
}

