// WiFi 재연결 버튼 실행
void doWifiReconnect(){
  connectWiFi();
  if(WiFi.status()==WL_CONNECTED){
    wifiDisconnectedAlert=false;
    lastWifiConnectedState=true;
    
    // 재연결 버튼은 WiFi 연결만 수행한다. API는 사용자가 API Refresh 버튼으로 직접 실행한다.
    updateEssModeByTomorrowForecast();
    if(currentPage==PAGE_SYSTEM) drawSystemPage();
  }
}

// API 새로고침 버튼 실행
void doApiRefresh(){
  if(WiFi.status()!=WL_CONNECTED||initialApiTaskRunning) return;

  initialApiTaskRunning=true;

  // API 새로고침도 시간 기준이 필요하므로 먼저 NTP 시간 동기화를 확인한다.
  trafficLedMode=LED_MODE_TIME_SYNC;
  trafficLedLastToggle = 0;
  trafficLedBlinkState = false;
  apiStatus="API: TIME SYNC";
  if(currentPage==PAGE_SYSTEM) drawSystemPage();

  bool tok = ensureTimeSyncedForApi(20000);
  if(currentPage==PAGE_SYSTEM) updateSystemPageTimeOnly();
  if(!tok){
    apiStatus="API: TIME FAIL";
    initialApiTaskRunning=false;
    trafficLedMode=LED_MODE_API_FAILED;
    if(currentPage==PAGE_SYSTEM) drawSystemPage();
    return;
  }

  trafficLedMode=LED_MODE_API_LOADING;
  startApiLedHwTimer();              // HW 타이머로 LED 전체 점멸 시작
  apiStatus="API: CALLING";
  if(currentPage==PAGE_SYSTEM) updateSystemPageApiSync();
  fetchKmaForecastWithRetry(3, 7000);
  stopApiLedHwTimer();               // LED 점멸 중지
  initialKmaFetched=true;
  initialApiTaskRunning=false;
  if(isApiForecastOk()){
    loadActualDataFromNVS();
    updateEssModeByTomorrowForecast();
    // LED를 ESS 모드에 맞게 재설정
    trafficLedMode=isEcoModeActive()?LED_MODE_ESS_ECO:LED_MODE_ESS_NORMAL;
    updateEssSourceLeds();
  } else {
    trafficLedMode=LED_MODE_API_FAILED;
    setTrafficLeds(false,false,false);
  }
  lastApiSync=getTimeOnlyString();
  if(currentPage==PAGE_SYSTEM) drawSystemPage();
}

void handleSystemTap(int x,int y){
  Serial.printf("[SysTap] x=%d y=%d\n",x,y);

  // WiFi 재연결 버튼 영역: x=4~156, y=193~233
  if(pointInRect(x,y,4,193,152,40)){
    Serial.println("[SysTap] WiFi Reconnect btn");
    if(wifiStatus=="CONNECTING"||WiFi.status()==WL_CONNECTED){
      Serial.println("[SysTap] already connected/connecting, skip");
      return;
    }
    doWifiReconnect();
    return;
  }
  // API 새로고침 버튼 영역: x=160~316, y=193~233
  if(pointInRect(x,y,160,193,156,40)){
    Serial.println("[SysTap] API Refresh btn");
    doApiRefresh();
    return;
  }
}

// [수정] 스와이프/화살표 방향
// 좌→우 스와이프(dx>0) = prevPage(왼쪽 페이지)
// 우→좌 스와이프(dx<0) = nextPage(오른쪽 페이지)
// < 화살표(lx<=35) = prevPage,  > 화살표(lx>=285) = nextPage
// ※ 하드웨어에서 반대로 동작하는 경우 아래 nextPage/prevPage를 교체
void handleTouch(){
  static int lx=0, ly=0;
  if(ts.touched()){
    TS_Point p=ts.getPoint();
    int sx=rawToScreenX(p), sy=rawToScreenY(p);
    if(!touching){touching=true;startX=sx;startY=sy;}
    lx=sx; ly=sy;
  } else {
    if(touching){
      int dx=lx-startX, dy=ly-startY;
      if(abs(dx)>55&&abs(dx)>abs(dy)*1.4f){
        // 스와이프: 오른쪽(dx>0)=이전 페이지, 왼쪽(dx<0)=다음 페이지
        if(dx>0) prevPage(); else nextPage();
      } else if(abs(dx)<50&&abs(dy)<50){
        if(ly<=36){
          // 화살표: 좌(<)=이전 페이지, 우(>)=다음 페이지
          if(lx<=35)       prevPage();
          else if(lx>=285) nextPage();
        } else if(currentPage==PAGE_LOAD)    handleLoadControlTap(lx,ly);
          else if(currentPage==PAGE_SYSTEM)  handleSystemTap(lx,ly);
      }
      touching=false;
    }
  }
}

// ================= WIFI =================
void connectWiFi(){
  wifiStatus="CONNECTING";
  trafficLedMode=LED_MODE_WIFI_CONNECTING;
  trafficLedLastToggle=millis();
  trafficLedBlinkState=false;

  // 연결 시도 시작: 빨강/초록은 끄고 노란색만 점멸
  setTrafficLeds(false,false,false);
  drawSystemPage();

  WiFi.mode(WIFI_STA);
  WiFi.disconnect(true);
  delay(300);

  WiFi.begin(WIFI_SSID,WIFI_PASS);

  unsigned long sm=millis();
  unsigned long lastBlinkMs=0;
  bool yBlink=false;

  while(WiFi.status()!=WL_CONNECTED && millis()-sm<10000UL){
    // WiFi 연결 중에는 다른 LED 상태 함수에 의존하지 않고 노란색 LED를 직접 점멸
    if(millis()-lastBlinkMs>=250UL){
      lastBlinkMs=millis();
      yBlink=!yBlink;
      digitalWrite(TRAFFIC_LED_R_PIN,LOW);
      digitalWrite(TRAFFIC_LED_Y_PIN,yBlink?HIGH:LOW);
      digitalWrite(TRAFFIC_LED_G_PIN,LOW);
    }
    delay(20);
  }

  if(WiFi.status()==WL_CONNECTED){
    wifiStatus="CONNECTED";
    addEventLog("WiFi 연결 성공");
    wifiDisconnectedAlert=false;
    lastWifiConnectedState=true;
    trafficLedMode=LED_MODE_WIFI_CONNECTED;

    // 연결 성공: 노란색 OFF, 초록색 ON
    setTrafficLeds(false,false,true);

    if(!webServerReady) setupWebServer();
    Serial.printf("WiFi OK IP:%s\n",WiFi.localIP().toString().c_str());
  } else {
    wifiStatus="FAIL";
    wifiDisconnectedAlert=false;
    lastWifiConnectedState=false;
    trafficLedMode=LED_MODE_WIFI_FAILED;

    // 실패 시 일단 모두 OFF, 이후 loop에서 실패 표시 점멸
    setTrafficLeds(false,false,false);
    Serial.println("WiFi FAILED");
  }

  drawSystemPage();
}

// ================= 태양 위치 =================
SolarPos calcSolarPosition(int year,int month,int day,float hourUTC){
  float A=floor((14.0f-month)/12.0f),Y=year+4800.0f-A,M=month+12.0f*A-3.0f;
  float JD=day+floor((153.0f*M+2.0f)/5.0f)+365.0f*Y+floor(Y/4.0f)
           -floor(Y/100.0f)+floor(Y/400.0f)-32045.0f+hourUTC/24.0f-0.5f;
  float n=JD-2451545.0f;
  float L=fmod(280.460f+0.9856474f*n,360.0f);
  float g=fmod(357.528f+0.9856003f*n,360.0f);
  float gr=g*DEG_TO_RAD;
  float lam=L+1.915f*sin(gr)+0.020f*sin(2.0f*gr);
  float ep=23.439f-0.0000004f*n;
  float lamR=lam*DEG_TO_RAD, epR=ep*DEG_TO_RAD;
  float decl=asin(sin(epR)*sin(lamR));
  float B=(360.0f/365.0f)*(n-81.0f)*DEG_TO_RAD;
  float EoT=9.87f*sin(2.0f*B)-7.53f*cos(B)-1.5f*sin(B);
  float st=hourUTC+LONGITUDE_DEG/15.0f+EoT/60.0f;
  float HRA=(st-12.0f)*15.0f, HRAR=HRA*DEG_TO_RAD, latR=LATITUDE_DEG*DEG_TO_RAD;
  float sinAlt=sin(latR)*sin(decl)+cos(latR)*cos(decl)*cos(HRAR);
  float alt=asin(sinAlt)*RAD_TO_DEG;
  float cosAz=constrain((sin(decl)-sin(latR)*sinAlt)/(cos(latR)*cos(alt*DEG_TO_RAD)),-1.0f,1.0f);
  float az=acos(cosAz)*RAD_TO_DEG;
  if(sin(HRAR)>0) az=-az;
  return {alt, az};
}
float calcCosIncidenceAngle(float ad,float sd,float td,float pd){
  float aR=ad*DEG_TO_RAD,sR=sd*DEG_TO_RAD,tR=td*DEG_TO_RAD,pR=pd*DEG_TO_RAD;
  float sx=cos(aR)*sin(sR),sy=cos(aR)*cos(sR),sz=sin(aR);
  float nx=sin(tR)*sin(pR),ny=sin(tR)*cos(pR),nz=cos(tR);
  return constrain(sx*nx+sy*ny+sz*nz,0.0f,1.0f);
}
float calcAirMass(float a){
  if(a<=0)return 99.0f;
  float r=a*DEG_TO_RAD;
  return constrain(1.0f/(sin(r)+0.50572f*pow(a+6.07995f,-1.6364f)),1.0f,40.0f);
}
IrradComp calcDNI_DHI(float a,float h){
  if(a<=0)return{0,0};
  float AM=calcAirMass(a),hf=1.0f;
  if(h>60.0f)hf=constrain(1.0f-(h-60.0f)*0.003f,0.7f,1.0f);
  float DNI=1361.0f*pow(0.7f*hf,AM);
  return{DNI,DNI*0.10f};
}
float calcPOA(float D,float H,float c,float t){
  float tr=t*DEG_TO_RAD;
  return constrain(D*c+H*(1.0f+cos(tr))/2.0f,0.0f,1400.0f);
}
float calcCellTemp(float T,float G){return T+G*(NOCT-20.0f)/800.0f;}
float calcShadowFactor(float a){
  if(a<=0)return 0.5f;
  if(a>=SHADOW_ALTITUDE_THRESH_DEG)return 1.0f;
  return 0.5f+0.5f*(a/SHADOW_ALTITUDE_THRESH_DEG);
}
float skyToSunFactor(int s){
  if(s==1)return 1.0f; if(s==3)return 0.6f; if(s==4)return 0.25f; return 0.5f;
}
float estimateDailyWhAdvanced(const String&ds,int*sky,int*pop,int*reh,float*tmp,bool*sv,int sc,float*hOut=NULL){
  if(hOut) for(int i=0;i<SOLAR_SLOT_COUNT;i++) hOut[i]=0;
  if(sc==0) return 0;
  int yr=ds.substring(0,4).toInt(),mo=ds.substring(4,6).toInt(),dy=ds.substring(6,8).toInt();
  float tw=0, tp=PANEL_PEAK_W*PANEL_COUNT;
  for(int si=0;si<SOLAR_SLOT_COUNT;si++){
    int kst=SOLAR_SLOT_START_HOUR+si;
    if(!sv[si]) continue;
    float uh=kst-9.0f;
    SolarPos sp=calcSolarPosition(yr,mo,dy,uh);
    if(sp.altitude<=0) continue;
    float ci=calcCosIncidenceAngle(sp.altitude,sp.azimuth,PANEL_TILT_DEG,PANEL_AZIMUTH_DEG);
    IrradComp ir=calcDNI_DHI(sp.altitude,(float)reh[si]);
    float wf=skyToSunFactor(sky[si])*constrain(1.0f-pop[si]/200.0f,0.3f,1.0f);
    ir.DNI*=wf; ir.DHI*=wf;
    float poa=calcPOA(ir.DNI,ir.DHI,ci,PANEL_TILT_DEG);
    float tl=constrain(1.0f+TEMP_COEFF_PER_C*(calcCellTemp(tmp[si],poa)-25.0f),0.7f,1.1f);
    float wh=constrain(tp*(poa/1000.0f)*tl*calcShadowFactor(sp.altitude)*SYSTEM_EFFICIENCY,0.0f,tp);
    tw+=wh; if(hOut) hOut[si]=wh;
  }
  Serial.printf("  Daily total: %.2fWh\n",tw);
  return tw;
}

// ================= KMA 파싱 =================
String extractJsonStringValue(const String&o,const char*k){
  String p="\""+String(k)+"\":\"";
  int s=o.indexOf(p); if(s<0)return "";
  s+=p.length(); int e=o.indexOf("\"",s); if(e<0)return "";
  return o.substring(s,e);
}
void initForecastData(DayForecastData d[3]){
  for(int i=0;i<3;i++){
    for(int j=0;j<SOLAR_SLOT_COUNT;j++){
      d[i].skySlots[j]=1;d[i].popSlots[j]=0;
      d[i].rehSlots[j]=50;d[i].tempSlots[j]=15;d[i].slotValid[j]=false;
    }
    d[i].slotCount=0;
  }
}
void copyOneSlot(DayForecastData d[3],DayForecastData s[3],int di,int si){
  if(di<0||di>=3||si<0||si>=SOLAR_SLOT_COUNT||!s[di].slotValid[si])return;
  bool w=d[di].slotValid[si];
  d[di].skySlots[si]=s[di].skySlots[si]; d[di].popSlots[si]=s[di].popSlots[si];
  d[di].rehSlots[si]=s[di].rehSlots[si]; d[di].tempSlots[si]=s[di].tempSlots[si];
  d[di].slotValid[si]=true; if(!w)d[di].slotCount++;
}
void copyDayAllSlots(DayForecastData d[3],DayForecastData s[3],int di){
  for(int si=0;si<SOLAR_SLOT_COUNT;si++) copyOneSlot(d,s,di,si);
}
void parseKmaItemsAdvancedAppend(const String&pl,String dt[3],DayForecastData da[3]){
  int pos=0;
  while(true){
    int kp=pl.indexOf("\"baseDate\"",pos); if(kp<0)break;
    int is=pl.lastIndexOf("{",kp); if(is<0)break;
    int ie=pl.indexOf("}",kp); if(ie<0)break;
    String obj=pl.substring(is,ie+1); pos=ie+1;
    String cat=extractJsonStringValue(obj,"category");
    if(cat!="SKY"&&cat!="POP"&&cat!="REH"&&cat!="TMP") continue;
    String fd=extractJsonStringValue(obj,"fcstDate");
    String ft=extractJsonStringValue(obj,"fcstTime");
    if(ft.length()<4) continue;
    int hh=ft.substring(0,2).toInt();
    if(hh<SOLAR_SLOT_START_HOUR||hh>SOLAR_SLOT_END_HOUR) continue;
    int si=hh-SOLAR_SLOT_START_HOUR;
    int val=extractJsonStringValue(obj,"fcstValue").toInt();
    for(int d=0;d<3;d++){
      if(fd==dt[d]){
        if(cat=="SKY")      da[d].skySlots[si]=val;
        else if(cat=="POP") da[d].popSlots[si]=val;
        else if(cat=="REH") da[d].rehSlots[si]=val;
        else if(cat=="TMP") da[d].tempSlots[si]=(float)val;
        if(!da[d].slotValid[si]){da[d].slotValid[si]=true;da[d].slotCount++;}
      }
    }
  }
}
int extractJsonIntValue(const String&pl,const char*k){
  String p="\""+String(k)+"\":";
  int s=pl.indexOf(p); if(s<0)return -1;
  s+=p.length();
  while(s<(int)pl.length()&&(pl[s]==' '||pl[s]=='\t'||pl[s]=='\r'||pl[s]=='\n'))s++;
  bool q=(s<(int)pl.length()&&pl[s]=='\"'); if(q)s++; int e=s;
  while(e<(int)pl.length()){
    char c=pl[e];
    if(q?c=='\"':(c==','||c=='}'||c==' '||c=='\n'||c=='\r'))break;
    e++;
  }
  return pl.substring(s,e).toInt();
}
void mergeForecastByRefreshTime(DayForecastData fd[3],DayForecastData m5[3],DayForecastData n11[3],DayForecastData ld[3]){
  initForecastData(fd);
  struct tm ti; int nh=9; if(getLocalTime(&ti))nh=ti.tm_hour;
  for(int d=1;d<3;d++){
    copyDayAllSlots(fd,ld,d);
    for(int s=0;s<SOLAR_SLOT_COUNT;s++) if(!fd[d].slotValid[s]) copyOneSlot(fd,m5,d,s);
  }
  if(nh<12){copyDayAllSlots(fd,m5,0);}
  else{
    for(int s=0;s<SOLAR_SLOT_COUNT;s++){
      int sh=SOLAR_SLOT_START_HOUR+s;
      if(sh<=11)      copyOneSlot(fd,m5,0,s);
      else if(sh<nh){ copyOneSlot(fd,n11,0,s); if(!fd[0].slotValid[s])copyOneSlot(fd,m5,0,s);}
      else{           copyOneSlot(fd,ld,0,s);  if(!fd[0].slotValid[s])copyOneSlot(fd,n11,0,s); if(!fd[0].slotValid[s])copyOneSlot(fd,m5,0,s);}
    }
  }
}
bool fetchKmaForecastByBase(const String&bd,const String&bt,DayForecastData od[3]){
  String dt[3]={getDateStringOffset(0),getDateStringOffset(1),getDateStringOffset(2)};
  initForecastData(od);
  const int rp=500,mp=8; int tc=-1; bool got=false;
  for(int pg=1;pg<=mp;pg++){
    String url="http://apis.data.go.kr/1360000/VilageFcstInfoService_2.0/getVilageFcst";
    url+="?serviceKey="+KMA_KEY+"&pageNo="+String(pg)+"&numOfRows="+String(rp);
    url+="&dataType=JSON&base_date="+bd+"&base_time="+bt+"&nx="+String(NX)+"&ny="+String(NY);
    HTTPClient http; http.begin(url); http.setTimeout(15000);
    int hc=http.GET();
    Serial.printf("KMA pg%d: %d\n",pg,hc);
    if(hc!=200){http.end();if(pg==1)return false;break;}
    String pl=http.getString(); http.end();
    if(pl.indexOf("\"resultCode\":\"00\"")<0){if(pg==1)return false;break;}
    got=true;
    if(tc<0) tc=extractJsonIntValue(pl,"totalCount");
    parseKmaItemsAdvancedAppend(pl,dt,od);
    if(od[0].slotCount>=SOLAR_SLOT_COUNT&&od[1].slotCount>=SOLAR_SLOT_COUNT&&od[2].slotCount>=SOLAR_SLOT_COUNT)break;
    if(tc>0&&pg*rp>=tc)break;
    delay(80);
  }
  return got;
}
void fillAfterTomorrowFallback(DayForecastData fd[3]){
  if(fd[2].slotCount>0)return;
  int lh=getLatestKmaBaseHour();
  int ch[]={23,20,17,14,11,8,5,2};
  for(int i=0;i<8;i++){
    int h=ch[i]; if(lh!=23&&h>lh)continue;
    DayForecastData rd[3]; initForecastData(rd);
    String rd2=getBaseDateForHour(h), rt=twoDigitBaseTime(h);
    if(fetchKmaForecastByBase(rd2,rt,rd)&&rd[2].slotCount>0){
      copyDayAllSlots(fd,rd,2);
      Serial.printf("AFTER fallback OK: %s %s\n",rd2.c_str(),rt.c_str());
      return;
    }
  }
  Serial.println("AFTER fallback failed");
}
void fetchKmaForecast(){
  if(WiFi.status()!=WL_CONNECTED){
    wifiStatus="DISCONNECTED";
    addEventLog("WiFi 연결 해제");
    wifiDisconnectedAlert=true;
    apiStatus="API: OFFLINE";
    if(currentPage==PAGE_SYSTEM)drawSystemPage();
    return;
  }
  struct tm ti; int nh=9; if(getLocalTime(&ti))nh=ti.tm_hour;
  String md=getBaseDateForHour(5),mt2="0500";
  String nd=getBaseDateForHour(11),nt="1100";
  int lh=getLatestKmaBaseHour();
  String ld=getBaseDateForHour(lh), lt=twoDigitBaseTime(lh);
  apiStatus="API: CALL "+lt;

  DayForecastData m5[3],n11[3],latest[3],fd[3];
  initForecastData(m5);initForecastData(n11);initForecastData(latest);initForecastData(fd);
  fetchKmaForecastByBase(md,mt2,m5);
  if(nh>=12) fetchKmaForecastByBase(nd,nt,n11);
  else       for(int d=0;d<3;d++)copyDayAllSlots(n11,m5,d);
  if(lt==mt2&&ld==md)             for(int d=0;d<3;d++)copyDayAllSlots(latest,m5,d);
  else if(nh>=12&&lt==nt&&ld==nd) for(int d=0;d<3;d++)copyDayAllSlots(latest,n11,d);
  else                            fetchKmaForecastByBase(ld,lt,latest);
  mergeForecastByRefreshTime(fd,m5,n11,latest);
  fillAfterTomorrowFallback(fd);

  float rw[3]={0,0,0};
  for(int i=0;i<SOLAR_SLOT_COUNT;i++){
    todayHourlyGenWh[i]=0;
    tomorrowHourlyGenWh[i]=0;
    afterTomorrowHourlyGenWh[i]=0;
  }
  for(int d=0;d<3;d++){
    float* hourlyOut = NULL;
    if(d==0)      hourlyOut = todayHourlyGenWh;
    else if(d==1) hourlyOut = tomorrowHourlyGenWh;
    else if(d==2) hourlyOut = afterTomorrowHourlyGenWh;

    if(fd[d].slotCount>0)
      rw[d]=estimateDailyWhAdvanced(
        getDateStringOffset(d),
        fd[d].skySlots,fd[d].popSlots,fd[d].rehSlots,fd[d].tempSlots,
        fd[d].slotValid,fd[d].slotCount,
        hourlyOut
      );
  }
  todayGenWh=rw[0]; tomorrowGenWh=rw[1]; afterTomorrowGenWh=rw[2];
bool any=(fd[0].slotCount>0||fd[1].slotCount>0||fd[2].slotCount>0);
  if(any){
  apiStatus = (fd[2].slotCount>0) ? "API: OK " + lt : "API: OK NO AFTER";
  addEventLog(apiStatus);
}else{
  apiStatus = "API: NO DATA";
  addEventLog(apiStatus);
}
  lastApiSync=getTimeOnlyString();
  initialKmaFetched=true;
  if(any){
    updateEssModeByTomorrowForecast();
    trafficLedMode=isEcoModeActive()?LED_MODE_ESS_ECO:LED_MODE_ESS_NORMAL;
  } else {
    trafficLedMode=LED_MODE_API_FAILED;
  }
  if(currentPage==PAGE_SYSTEM)   drawSystemPage();
  if(currentPage==PAGE_FORECAST) drawForecastPage();
  if(currentPage==PAGE_MAIN)     drawMainPage();
  if(currentPage==PAGE_COMPARE)  drawComparePage();
}
bool isApiForecastOk(){
  return apiStatus.startsWith("API: OK")&&(todayGenWh>0||tomorrowGenWh>0||afterTomorrowGenWh>0);
}

bool fetchKmaForecastWithRetry(uint8_t tries, unsigned long retryDelayMs){
  for(uint8_t i=0; i<tries; i++){
    fetchKmaForecast();
    if(isApiForecastOk()) return true;

    Serial.printf("[KMA] boot/auto retry %d/%d failed: %s\n", i+1, tries, apiStatus.c_str());
    if(i < tries - 1){
      apiStatus = "API: RETRY " + String(i + 2) + "/" + String(tries);
      if(currentPage==PAGE_SYSTEM) updateSystemPageApiSync();
      unsigned long sm = millis();
      while(millis() - sm < retryDelayMs){
        updateTrafficLedBlink();
        delay(50);
      }
    }
  }
  return false;
}

// ================= API SYNC =================
bool ensureTimeSyncedForApi(unsigned long timeoutMs){
  configTime(9*3600,0,"kr.pool.ntp.org","pool.ntp.org","time.nist.gov");

  unsigned long startMs = millis();
  while(millis() - startMs < timeoutMs){
    if(waitForTimeSync(3000)) return true;
    if((millis() - startMs) > 12000UL){
      configTime(9*3600,0,"kr.pool.ntp.org","pool.ntp.org","time.nist.gov");
    }
    updateTrafficLedBlink();
    if(currentPage==PAGE_SYSTEM) updateSystemPageTimeOnly();
    delay(200);
  }
  return false;
}

void doApiSyncAfterWifi(){
  if(WiFi.status()!=WL_CONNECTED)return;

  initialApiTaskRunning=true;
  trafficLedMode=LED_MODE_TIME_SYNC;
  trafficLedLastToggle = 0;
  trafficLedBlinkState = false;
  apiStatus="API: TIME SYNC";
  if(currentPage==PAGE_SYSTEM) updateSystemPageApiSync();

  bool tok=ensureTimeSyncedForApi(45000);
  if(currentPage==PAGE_SYSTEM) updateSystemPageTimeOnly();
  if(!tok){
    apiStatus="API: TIME FAIL";
    initialApiTaskRunning=false;
    trafficLedMode=LED_MODE_API_FAILED;
    if(currentPage==PAGE_SYSTEM) updateSystemPageApiSync();
    return;
  }

  trafficLedMode=LED_MODE_API_LOADING;
  apiStatus="API: CALLING";
  startApiLedHwTimer();   
  if(currentPage==PAGE_SYSTEM) updateSystemPageApiSync();
  fetchKmaForecastWithRetry(3, 7000);
  stopApiLedHwTimer();    
  initialKmaFetched=true;
  initialApiTaskRunning=false;
  if(isApiForecastOk()){
    loadActualDataFromNVS();
    updateEssModeByTomorrowForecast();
    trafficLedMode=isEcoModeActive()?LED_MODE_ESS_ECO:LED_MODE_ESS_NORMAL;
    updateEssSourceLeds();
    currentPage=PAGE_MAIN;
    drawMainPage();
  } else {
    trafficLedMode=LED_MODE_API_FAILED;
    setTrafficLeds(false,false,false);
    if(currentPage==PAGE_SYSTEM) drawSystemPage();
  }
}

// ================= SETUP =================
void setup(){
  Serial.begin(115200);
  pinMode(TFT_CS,OUTPUT);     pinMode(TOUCH_CS,OUTPUT);
  pinMode(LED_LOAD_PIN,OUTPUT);   pinMode(MOTOR_RELAY_PIN,OUTPUT);
  pinMode(POWER_RELAY_PIN,OUTPUT);
  pinMode(TRAFFIC_LED_R_PIN,OUTPUT);
  pinMode(TRAFFIC_LED_Y_PIN,OUTPUT);
  pinMode(TRAFFIC_LED_G_PIN,OUTPUT);
  ledLoadOn=motorLoadOn=allLoadOn=false;
  digitalWrite(LED_LOAD_PIN,LOW);
  digitalWrite(MOTOR_RELAY_PIN,MOTOR_RELAY_OFF);
  digitalWrite(POWER_RELAY_PIN,POWER_RELAY_BATTERY_ON);
  setTrafficLeds(false,false,false);

  // 저장된 ECO 전환 배터리 잔량을 부팅 시 복원한다.
  // 저장값이 없으면 기본값 30%를 그대로 사용한다.
  loadEcoThresholdFromNVS();

  digitalWrite(TFT_CS,HIGH); digitalWrite(TOUCH_CS,HIGH);
  SPI.begin(SPI_SCK,SPI_MISO,SPI_MOSI);
  initINA3221();
  tft.begin(); tft.setRotation(3);
  ts.begin(); ts.setRotation(3);

  // [부팅1] 짧은 스플래시 후 즉시 WiFi 연결 단계로 진입
  drawBootSplashWithFastLedSequence();

  // [부팅2] 시스템 페이지 초기 표시
  currentPage=PAGE_SYSTEM;
  wifiStatus="---"; lastApiSync="--:--"; apiStatus="API: WAIT";
  drawSystemPage();
  delay(50);

  // [부팅3] INA3221 초기 측정
  updateSolarPowerFromINA3221();
  updateBatteryFromINA3221();
  updateLoadPowerFromINA3221();

  // [부팅4] WiFi 연결 (노란LED 점멸)
  connectWiFi();

  
  // [부팅6] NTP + KMA API (WiFi 연결 시만)
  if(WiFi.status()==WL_CONNECTED){
    initialApiTaskStarted=true;
    doApiSyncAfterWifi();
  }
  Serial.println("ESS Display UI Start");
}

// ================= WIFI MONITOR =================
void monitorWiFiConnection(){
  static unsigned long lastCheckMs=0;
  if(millis()-lastCheckMs<2000UL) return;
  lastCheckMs=millis();

  bool nowConnected=(WiFi.status()==WL_CONNECTED);
  if(nowConnected){
    if(wifiStatus!="CONNECTED"){
      wifiStatus="CONNECTED";
      wifiDisconnectedAlert=false;
      lastWifiConnectedState=true;
      trafficLedMode=isEcoModeActive()?LED_MODE_ESS_ECO:LED_MODE_ESS_NORMAL;
      if(currentPage==PAGE_SYSTEM) drawSystemPage();
    }
    return;
  }

  // 부팅 후 한 번이라도 연결되었던 WiFi가 중간에 끊긴 경우
  if(lastWifiConnectedState && wifiStatus!="DISCONNECTED" && wifiStatus!="CONNECTING"){
    wifiStatus="DISCONNECTED";
    wifiDisconnectedAlert=true;
    apiStatus="API: OFFLINE";
    trafficLedMode=isEcoModeActive()?LED_MODE_ESS_ECO:LED_MODE_ESS_NORMAL;
    Serial.println("[WiFi] disconnected during operation. Keep last KMA forecast and enable manual reconnect.");
    if(currentPage==PAGE_SYSTEM) drawSystemPage();
  }
}

// ================= LOOP =================
void loop(){
  if(webServerReady) server.handleClient();
monitorWiFiConnection();
  updateTrafficLedBlink();
  updateEcoExternalDelay();
  updateManualExternalDelay();
  handleTouch();

  // 1초마다 센서 갱신
  static unsigned long lastSensorMs=0;
  if(millis()-lastSensorMs>1000){
    lastSensorMs=millis();
    updateSolarPowerFromINA3221();
    updateBatteryFromINA3221();
    updateLoadPowerFromINA3221();
    updateActualSolarData();
    if(currentPage==PAGE_MAIN) updateMainDynamicValues();
  }

  // 시스템 페이지 시간 1분마다 업데이트
  static unsigned long lastSysTimeMs=0;
  if(currentPage==PAGE_SYSTEM && millis()-lastSysTimeMs>60000){
    lastSysTimeMs=millis();
    updateSystemPageTimeOnly();
  }

  // 30분마다 KMA API 재호출
  static unsigned long lastApiMs=0;
  if(millis()-lastApiMs>1800000UL){
    lastApiMs=millis();
    if(WiFi.status()==WL_CONNECTED){
      wifiStatus="CONNECTED";
      startApiLedHwTimer();
      fetchKmaForecast();
      stopApiLedHwTimer();
      if(isApiForecastOk()){
        updateEssModeByTomorrowForecast();
        updateEssSourceLeds();
      } else {
        trafficLedMode=LED_MODE_API_FAILED;
      }
    } else {
      // 오프라인 상태에서는 마지막 API 계산값으로 계속 동작하고 자동 재연결/자동 API 호출은 하지 않는다.
      wifiStatus="DISCONNECTED";
      wifiDisconnectedAlert=true;
      apiStatus="API: OFFLINE";
      if(currentPage==PAGE_SYSTEM) drawSystemPage();
    }
  }
}
